PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/book_store
JWT_SECRET=your_super_secret_key
JWT_EXPIRES_IN=7d

# Reset password: token hết hạn sau (ms), mặc định 1 giờ
PASSWORD_RESET_EXPIRES_MS=3600000

# Chỉ bật khi dev/test: trả resetToken trong JSON forgot-password (KHÔNG bật production)
EXPOSE_RESET_TOKEN_IN_RESPONSE=false

# SMTP config for real-time forgot-password email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM=Book Store <your_email@gmail.com>

# Frontend reset-password page URL
FRONTEND_RESET_PASSWORD_URL=http://localhost:5173/reset-password

# Optional app name used in email subject
APP_NAME=Book Store

# CORS for frontend
CORS_ORIGINS=http://localhost:5173,http://localhost:5000
SOCKET_CORS_ORIGIN=http://localhost:5173,http://localhost:5000

# Chat/socket debug logs (set true only when debugging)
LOG_CHAT_REQUESTS=false
LOG_SOCKET_EVENTS=false

# Socket timeout tuning (avoid frequent disconnects on unstable network)
SOCKET_PING_INTERVAL_MS=25000
SOCKET_PING_TIMEOUT_MS=60000
SOCKET_CONNECT_TIMEOUT_MS=20000
